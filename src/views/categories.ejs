<%- include('partials/header') %>

    <main class="container">
        <h1>
            <%= title %>
        </h1>
        <p>Browse service opportunities by category:</p>
        <ul class="category-list">
            <% categories.forEach(category=> { %>
                <li>
                    <%= category.name %>
                </li>
                <% }); %>
        </ul>
    </main>

    <%- include('partials/footer') %>