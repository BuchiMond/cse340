<%- include('partials/header') %>

<main class="container">
    <h1><%= title %></h1>
    <h2 class="section-heading">Upcoming Service Projects</h2>
    <% if (projects && projects.length > 0) { %>
        <ul class="project-list">
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a> -
                    <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>There are no upcoming service projects at this time.</p>
    <% } %>
</main>

<%- include('partials/footer') %>
